# Copy this file to .env and fill in your actual values

# Flask
SECRET_KEY=your-secret-key-here

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_SECRET=your-paypal-secret
PAYPAL_MODE=sandbox

# URLs
API_BASE_URL=https://your-api.vercel.app
FRONTEND_URL=https://your-username.github.io/forced-learning-app

# JWT
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=604800

# CORS
CORS_ORIGINS=https://your-username.github.io,http://localhost:3000

# Data CDN (GitHub via jsDelivr)
DATA_BASE_URL=https://cdn.jsdelivr.net/gh/your-username/flashcard-data@courses/

# HMAC Secret
DATA_SIGN_SECRET=your-hmac-secret-for-data-integrity
